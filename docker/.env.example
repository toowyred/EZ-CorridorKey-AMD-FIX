# ============================================================
#  EZ-CorridorKey — options
#
#  All of these are passed into 1-install.sh on first start.
#  To re-apply after changing:
#    docker exec -it corridorkey-gpu rm /app/.install_complete
#    docker compose restart corridorkey-gpu
# ============================================================

# ── Python version (3.10–3.13) ────────────────────────────────
CORRIDORKEY_PYTHON_VERSION=3.11

# ── SAM2 tracker ─────────────────────────────────────────────
# Set to "n" to skip (faster first start, disables Track Mask)
CORRIDORKEY_INSTALL_SAM2=y
CORRIDORKEY_PREDOWNLOAD_SAM2=y

# ── Optional large models ─────────────────────────────────────
CORRIDORKEY_INSTALL_GVM=y
CORRIDORKEY_INSTALL_VIDEOMAMA=n

# ── Display resolution ────────────────────────────────────────
# WIDTHxHEIGHTxDEPTH — x24 is color depth (24-bit RGB), not FPS
CORRIDORKEY_RESOLUTION=2560x1440x24

# ── GPU optimization ──────────────────────────────────────────
# auto | speed | lowvram — blank = app auto-detects
CORRIDORKEY_OPT_MODE=
